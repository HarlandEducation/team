2Fsc-if>\n                <sc-if value=\"{{ card.isLoser }}\" hint-placeholder-val=\"{{ true }}\">\n                  <div style=\"width:42px;height:42px;color:#9a201a;\">{{ card.iconEl }}<\u002Fdiv>\n                  <div style=\"margin-top:6px;font-family:'Marcellus',serif;font-size:10px;color:#a06b3a;letter-spacing:.08em;\">{{ card.faceLabel }}<\u002Fdiv>\n                <\u002Fsc-if>\n              <\u002Fdiv>\n\n            <\u002Fdiv>\n          <\u002Fdiv>\n        <\u002Fsc-for>\n      <\u002Fdiv>\n\n      <div style=\"text-align:center;margin-top:24px;\">\n        <button onclick=\"{{ openWall }}\" style=\"background:none;border:none;color:rgba(246,236,218,.7);font-size:13px;font-weight:600;cursor:pointer;text-decoration:underline;text-underline-offset:4px;\">Festival Wall →<\u002Fbutton>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- =================== RESULT OVERLAY (fresh play) =================== -->\n  <sc-if value=\"{{ showResult }}\">\n    <div style=\"position:fixed;inset:0;z-index:40;background:rgba(60,12,9,.72);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;padding:24px;\">\n      <div style=\"width:100%;max-width:430px;background:#f7efe0;border:1px solid #d9b35a;border-radius:18px;padding:34px 30px;text-align:center;box-shadow:0 30px 70px rgba(0,0,0,.5);color:#3a2017;animation:dbfRise .55s cubic-bezier(.2,.7,.2,1) both;\">\n        <sc-if value=\"{{ ovWon }}\" hint-placeholder-val=\"{{ true }}\">\n          <div style=\"width:96px;height:96px;margin:0 auto;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:0;font-size:58px;background:radial-gradient(circle at 38% 30%,#a4231a,#6e1410 72%);border:3px solid #f6e2a0;animation:dbfGlow 1.9s ease-in-out infinite;\">\n            <span style=\"line-height:1;filter:sepia(1) saturate(2.4) hue-rotate(-14deg) brightness(1.05) contrast(1.05) drop-shadow(0 1px 2px rgba(60,12,9,.45));\">🐉<\u002Fspan>\n          <\u002Fdiv>\n          <div style=\"margin-top:18px;font-size:12px;letter-spacing:.3em;color:#c89a3a;font-weight:800;\">A GOLDEN CARD!<\u002Fdiv>\n          <h2 style=\"font-family:'Marcellus',serif;font-weight:400;font-size:36px;margin:6px 0 4px;color:#9a201a;\">You won {{ prizeLabel }}<\u002Fh2>\n        <\u002Fsc-if>\n        <sc-if value=\"{{ ovLost }}\" hint-placeholder-val=\"{{ true }}\">\n          <div style=\"width:84px;height:84px;margin:0 auto;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:20px;color:#9a201a;background:#efe3cd;border:2px solid #d9b35a;\">\n            <svg viewBox=\"0 0 48 48\" width=\"100%\" height=\"100%\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M24 8 L40 36 L8 36 Z\"><\u002Fpath><path d=\"M24 8 L24 36\"><\u002Fpath><path d=\"M16 22 L32 22\"><\u002Fpath><path d=\"M24 8 L20 4 M24 8 L28 4\"><\u002Fpath><\u002Fsvg>\n          <\u002Fdiv>\n          <div style=\"margin-top:18px;font-size:12px;letter-spacing:.3em;color:#a06b3a;font-weight:800;\">NOT A GOLDEN CARD<\u002Fdiv>\n          <h2 style=\"font-family:'Marcellus',serif;font-weight:400;font-size:32px;margin:6px 0 4px;color:#9a201a;\">So close this time<\u002Fh2>\n        <\u002Fsc-if>\n\n        <div style=\"display:flex;align-items:center;justify-content:center;gap:7px;margin-top:14px;\">\n          <sc-if value=\"{{ ovWon }}\" hint-placeholder-val=\"{{ true }}\"><span style=\"width:18px;height:18px;color:#e0a93a;display:inline-flex;\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M3 8 L7 12 L12 5 L17 12 L21 8 L19 19 L5 19 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan><\u002Fsc-if>\n          <span style=\"font-weight:800;font-size:16px;color:#3a2017;\">{{ ovName }}<\u002Fspan>\n        <\u002Fdiv>\n        <div style=\"margin-top:14px;background:#fffdf7;border:1px solid #e6d6b0;border-left:3px solid #d9b35a;border-radius:8px;padding:13px 15px;text-align:left;font-size:14px;line-height:1.55;color:#5a4030;font-style:italic;\">“{{ ovAnswer }}”<\u002Fdiv>\n\n        <button onclick=\"{{ openWall }}\" style=\"margin-top:24px;width:100%;border:none;border-radius:10px;padding:14px;font-size:14px;font-weight:800;color:#5e110d;cursor:pointer;background:linear-gradient(100deg,#e8c155,#f6e2a0,#e8c155);box-shadow:0 8px 18px rgba(0,0,0,.18);\">See the Festival Wall →<\u002Fbutton>\n        <div style=\"margin-top:12px;font-size:12px;color:#a98a55;\">You've used your one pick. Thanks for playing!<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- =================== LOCKED (returning) =================== -->\n  <sc-if value=\"{{ isLocked }}\">\n    <div style=\"position:relative;width:100%;max-width:430px;background:#f7efe0;border:1px solid #d9b35a;border-radius:18px;padding:34px 30px;text-align:center;box-shadow:0 30px 70px rgba(0,0,0,.4);color:#3a2017;animation:dbfRise .5s cubic-bezier(.2,.7,.2,1) both;\">\n      <div style=\"font-size:12px;letter-spacing:.3em;color:#a06b3a;font-weight:800;\">YOU'VE ALREADY ENTERED<\u002Fdiv>\n      <sc-if value=\"{{ lkWon }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"width:88px;height:88px;margin:18px auto 0;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:0;font-size:52px;background:radial-gradient(circle at 38% 30%,#a4231a,#6e1410 72%);border:3px solid #f6e2a0;box-shadow:0 0 16px rgba(236,198,89,.6);\">\n          <span style=\"line-height:1;filter:sepia(1) saturate(2.4) hue-rotate(-14deg) brightness(1.05) contrast(1.05) drop-shadow(0 1px 2px rgba(60,12,9,.45));\">🐉<\u002Fspan>\n        <\u002Fdiv>\n        <h2 style=\"font-family:'Marcellus',serif;font-weight:400;font-size:30px;margin:14px 0 0;color:#9a201a;\">You won {{ prizeLabel }}!<\u002Fh2>\n      <\u002Fsc-if>\n      <sc-if value=\"{{ lkLost }}\" hint-placeholder-val=\"{{ true }}\">\n        <div style=\"width:78px;height:78px;margin:18px auto 0;border-radius:50%;display:flex;align-items:center;justify-content:center;padding:18px;color:#9a201a;background:#efe3cd;border:2px solid #d9b35a;\">\n          <svg viewBox=\"0 0 48 48\" width=\"100%\" height=\"100%\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M24 8 L40 36 L8 36 Z\"><\u002Fpath><path d=\"M24 8 L24 36\"><\u002Fpath><path d=\"M16 22 L32 22\"><\u002Fpath><path d=\"M24 8 L20 4 M24 8 L28 4\"><\u002Fpath><\u002Fsvg>\n        <\u002Fdiv>\n        <h2 style=\"font-family:'Marcellus',serif;font-weight:400;font-size:28px;margin:14px 0 0;color:#9a201a;\">Not a winner this time<\u002Fh2>\n      <\u002Fsc-if>\n      <div style=\"display:flex;align-items:center;justify-content:center;gap:7px;margin-top:12px;\">\n        <sc-if value=\"{{ lkWon }}\" hint-placeholder-val=\"{{ true }}\"><span style=\"width:18px;height:18px;color:#e0a93a;display:inline-flex;\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M3 8 L7 12 L12 5 L17 12 L21 8 L19 19 L5 19 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan><\u002Fsc-if>\n        <span style=\"font-weight:800;font-size:16px;\">{{ lkName }}<\u002Fspan>\n      <\u002Fdiv>\n      <div style=\"margin-top:14px;background:#fffdf7;border:1px solid #e6d6b0;border-left:3px solid #d9b35a;border-radius:8px;padding:13px 15px;text-align:left;font-size:14px;line-height:1.55;color:#5a4030;font-style:italic;\">“{{ lkAnswer }}”<\u002Fdiv>\n      <button onclick=\"{{ openWall }}\" style=\"margin-top:24px;width:100%;border:none;border-radius:10px;padding:14px;font-size:14px;font-weight:800;color:#5e110d;cursor:pointer;background:linear-gradient(100deg,#e8c155,#f6e2a0,#e8c155);box-shadow:0 8px 18px rgba(0,0,0,.18);\">See the Festival Wall →<\u002Fbutton>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- =================== FESTIVAL WALL =================== -->\n  <sc-if value=\"{{ showWall }}\">\n    <div style=\"position:fixed;inset:0;z-index:50;background:rgba(60,12,9,.78);backdrop-filter:blur(7px);-webkit-backdrop-filter:blur(7px);display:flex;align-items:center;justify-content:center;padding:24px;\">\n      <div style=\"width:100%;max-width:560px;max-height:84vh;display:flex;flex-direction:column;background:#f7efe0;border:1px solid #d9b35a;border-radius:18px;box-shadow:0 30px 70px rgba(0,0,0,.5);overflow:hidden;animation:dbfRise .5s cubic-bezier(.2,.7,.2,1) both;color:#3a2017;\">\n        <div style=\"padding:24px 26px 18px;border-bottom:1px solid #e6d6b0;display:flex;align-items:flex-start;justify-content:space-between;gap:16px;background:linear-gradient(160deg,#9a201a,#7d1610);\">\n          <div>\n            <div style=\"font-size:11px;letter-spacing:.3em;color:#f3d77a;font-weight:800;\">FESTIVAL WALL<\u002Fdiv>\n            <h2 style=\"font-family:'Marcellus',serif;font-weight:400;font-size:25px;margin:5px 0 0;color:#fdf6e6;\">Everyone's long-weekend plans<\u002Fh2>\n            <div style=\"margin-top:7px;font-size:13px;color:rgba(246,236,218,.82);display:flex;align-items:center;gap:6px;\"><span style=\"width:15px;height:15px;color:#f3d77a;display:inline-flex;\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M3 8 L7 12 L12 5 L17 12 L21 8 L19 19 L5 19 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan>{{ winnerText }}<\u002Fdiv>\n          <\u002Fdiv>\n          <button onclick=\"{{ closeWall }}\" style=\"flex:none;width:34px;height:34px;border-radius:50%;border:1px solid rgba(243,215,122,.5);background:rgba(255,255,255,.08);color:#f3d77a;font-size:18px;cursor:pointer;line-height:1;\">×<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"overflow-y:auto;padding:10px 14px 18px;\">\n          <sc-for list=\"{{ wallList }}\" as=\"p\" hint-placeholder-count=\"4\">\n            <div style=\"display:flex;gap:13px;align-items:flex-start;padding:14px 12px;border-bottom:1px solid #ece0c6;background:{{ p.rowBg }};border-radius:10px;margin-top:6px;\">\n              <div style=\"position:relative;flex:none;width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Marcellus',serif;font-size:17px;font-weight:600;color:#fdf6e6;background:{{ p.avatarBg }};\">\n                {{ p.initial }}\n                <sc-if value=\"{{ p.won }}\" hint-placeholder-val=\"{{ true }}\">\n                  <span style=\"position:absolute;top:-9px;left:50%;transform:translateX(-50%);width:20px;height:20px;color:#e0a93a;\"><svg viewBox=\"0 0 24 24\" fill=\"currentColor\"><path d=\"M3 8 L7 12 L12 5 L17 12 L21 8 L19 19 L5 19 Z\"><\u002Fpath><\u002Fsvg><\u002Fspan>\n                <\u002Fsc-if>\n              <\u002Fdiv>\n              <div style=\"flex:1;min-width:0;\">\n                <div style=\"display:flex;align-items:center;gap:8px;\">\n                  <span style=\"font-weight:800;font-size:15px;color:#3a2017;\">{{ p.name }}<\u002Fspan>\n                  <sc-if value=\"{{ p.won }}\" hint-placeholder-val=\"{{ true }}\"><span style=\"font-size:10px;font-weight:800;letter-spacing:.08em;color:#9a201a;background:#f6e2a0;border:1px solid #e0c977;padding:2px 7px;border-radius:20px;\">WINNER · {{ prizeLabel }}<\u002Fspan><\u002Fsc-if>\n                <\u002Fdiv>\n                <div style=\"margin-top:4px;font-size:13.5px;line-height:1.5;color:#5a4030;\">{{ p.answer }}<\u002Fdiv>\n              <\u002Fdiv>\n            <\u002Fdiv>\n          <\u002Fsc-for>\n          <sc-if value=\"{{ wallEmpty }}\" hint-placeholder-val=\"{{ true }}\">\n            <div style=\"text-align:center;padding:40px 20px;color:#a98a55;font-size:14px;\">No one has played yet — be the first!<\u002Fdiv>\n          <\u002Fsc-if>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsc-if>\n\n  <!-- confetti -->\n  <canvas ref=\"{{ confettiRef }}\" style=\"position:fixed;inset:0;z-index:60;pointer-events:none;width:100%;height:100%;\"><\u002Fcanvas>\n\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{\n  &quot;$preview&quot;: { &quot;width&quot;: 1180, &quot;height&quot;: 820 },\n  &quot;prizeLabel&quot;: { &quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;NT$100&quot;, &quot;tsType&quot;: &quot;string&quot; },\n  &quot;questionText&quot;: { &quot;editor&quot;: &quot;text&quot;, &quot;default&quot;: &quot;What will you be doing this long weekend for Dragon Boat Festival?&quot;, &quot;tsType&quot;: &quot;string&quot; },\n  &quot;numWinners&quot;: { &quot;editor&quot;: &quot;int&quot;, &quot;default&quot;: 3, &quot;min&quot;: 1, &quot;max&quot;: 6, &quot;tsType&quot;: &quot;number&quot; }\n}\">\nclass Component extends DCLogic {\n  state = {\n    screen: 'entry',     // entry | board | locked\n    name: '',\n    answer: '',\n    winners: [],\n    chosen: null,\n    flipped: false,\n    showResult: false,\n    won: false,\n    showWall: false,\n    participants: [],\n    myResult: null,\n  };\n\n  SEED = [\n    { name: 'Mei-Ling', answer: 'Heading to Lukang to watch the dragon boat races with the whole family.', won: true, ts: 1 },\n    { name: 'Jia-Hao', answer: 'Wrapping zongzi with grandma and eating far too many of them.', won: false, ts: 2 },\n    { name: 'Ava Chen', answer: 'A quiet weekend hiking up in Yangmingshan to escape the city.', won: false, ts: 3 },\n    { name: 'Wei', answer: 'Driving down to Tainan to see old friends for the long weekend.', won: false, ts: 4 },\n  ];\n\n  componentDidMount() {\n    let parts = [];\n    try { parts = JSON.parse(localStorage.getItem('dbf_participants') || '[]'); } catch (e) {}\n    if (!Array.isArray(parts) || parts.length === 0) {\n      parts = this.SEED.slice();\n      localStorage.setItem('dbf_participants', JSON.stringify(parts));\n    }\n    let myResult = null;\n    try { myResult = JSON.parse(localStorage.getItem('dbf_played') || 'null'); } catch (e) {}\n    this.setState({\n      participants: parts,\n      myResult: myResult,\n      screen: myResult ? 'locked' : 'entry',\n      winners: this.pickWinners(),\n    });\n  }\n\n  componentWillUnmount() { if (this._raf) cancelAnimationFrame(this._raf); }\n\n  numWinners() {\n    const n = this.props.numWinners ?? 3;\n    return Math.max(1, Math.min(6, n));\n  }\n\n  pickWinners() {\n    const s = new Set();\n    const target = Math.min(this.numWinners(), 15);\n    while (s.size < target) s.add(Math.floor(Math.random() * 16));\n    return [...s];\n  }\n\n  onName = (e) => this.setState({ name: e.target.value });\n  onAnswer = (e) => this.setState({ answer: e.target.value });\n\n  canStart() { return this.state.name.trim().length > 0 && this.state.answer.trim().length > 0; }\n\n  start = () => {\n    if (!this.canStart()) return;\n    this.setState({ screen: 'board', chosen: null, flipped: false });\n  };\n\n  choose = (i) => {\n    if (this.state.chosen !== null) return;\n    const won = this.state.winners.includes(i);\n    this.setState({ chosen: i });\n    setTimeout(() => this.setState({ flipped: true }), 70);\n    setTimeout(() => {\n      const entry = { name: this.state.name.trim(), answer: this.state.answer.trim(), won, ts: Date.now() };\n      const parts = [entry, ...this.state.participants];\n      try {\n        localStorage.setItem('dbf_participants', JSON.stringify(parts));\n        localStorage.setItem('dbf_played', JSON.stringify(entry));\n      } catch (e) {}\n      this.setState({ showResult: true, won, participants: parts, myResult: entry });\n      if (won) this.launchConfetti();\n    }, 900);\n  };\n\n  openWall = () => this.setState({ showWall: true });\n  closeWall = () => this.setState({ showWall: false });\n\n  reset = () => {\n    try { localStorage.removeItem('dbf_played'); } catch (e) {}\n    if (this._raf) cancelAnimationFrame(this._raf);\n    this.setState({\n      screen: 'entry', name: '', answer: '', chosen: null, flipped: false,\n      showResult: false, won: false, showWall: false, myResult: null,\n      winners: this.pickWinners(),\n    });\n  };\n\n  launchConfetti() {\n    const cv = this._confetti;\n    if (!cv) return;\n    const ctx = cv.getContext('2d');\n    const W = cv.width = window.innerWidth;\n    const H = cv.height = window.innerHeight;\n    const colors = ['#e8c155', '#f6e2a0', '#9a201a', '#fdf6e6', '#c0392b', '#d9b35a'];\n    const parts = [];\n    for (let i = 0; i < 160; i++) {\n      parts.push({\n        x: Math.random() * W, y: -20 - Math.random() * H,\n        w: 6 + Math.random() * 9, h: 8 + Math.random() * 12,\n        vy: 2.5 + Math.random() * 4.5, vx: -2 + Math.random() * 4,\n        rot: Math.random() * 6.28, vr: -0.25 + Math.random() * 0.5,\n        c: colors[i % colors.length],\n      });\n    }\n    let start = null;\n    const dur = 2900;\n    const step = (ts) => {\n      if (!start) start = ts;\n      const t = ts - start;\n      ctx.clearRect(0, 0, W, H);\n      parts.forEach((p) => {\n        p.x += p.vx; p.y += p.vy; p.rot += p.vr; p.vy += 0.04;\n        ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);\n        ctx.fillStyle = p.c; ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);\n        ctx.restore();\n      });\n      if (t < dur) this._raf = requestAnimationFrame(step);\n      else ctx.clearRect(0, 0, W, H);\n    };\n    this._raf = requestAnimationFrame(step);\n  }\n\n  iconEl(key) {\n    const wrap = (children) => React.createElement('svg', {\n      viewBox: '0 0 48 48', width: '100%', height: '100%', fill: 'none',\n      stroke: 'currentColor', strokeWidth: 2.4, strokeLinecap: 'round', strokeLinejoin: 'round',\n    }, children);\n    const p = (d, i) => React.createElement('path', { d, key: 'p' + i });\n    const c = (cx, cy, r, i, fill) => React.createElement('circle', { cx, cy, r, key: 'c' + i, fill: fill || 'none', stroke: fill ? 'none' : 'currentColor' });\n    const el = (cx, cy, rx, ry, i) => React.createElement('ellipse', { cx, cy, rx, ry, key: 'e' + i });\n    switch (key) {\n      case 'boat': return wrap([p('M6 28 Q24 41 42 28', 0), p('M6 28 Q3 21 9.5 21.5', 1), p('M42 28 Q46 23 40 21', 2), p('M16 30 L13 38', 3), p('M24 31 L24 39.5', 4), p('M32 30 L35 38', 5), c(16, 25.5, 2, 6), c(24, 26.5, 2, 7), c(32, 25.5, 2, 8)]);\n      case 'drum': return wrap([el(24, 14, 12, 4, 0), p('M12 14 L12 34', 1), p('M36 14 L36 34', 2), el(24, 34, 12, 4, 3), p('M12 18 L36 30', 4), p('M36 18 L12 30', 5), p('M30 6 L40 2', 6), p('M33 9 L43 5', 7)]);\n      case 'zongzi': return wrap([p('M24 8 L40 36 L8 36 Z', 0), p('M24 8 L24 36', 1), p('M16 22 L32 22', 2), p('M24 8 L20 4', 3), p('M24 8 L28 4', 4)]);\n      case 'egg': return wrap([p('M24 7 C16 7 14 21 14 26 a10 10 0 0 0 20 0 C34 21 32 7 24 7 Z', 0), p('M16 39 L32 39', 1), p('M19 35 L29 35', 2)]);\n      case 'pouch': return wrap([p('M16 14 Q24 8 32 14', 0), p('M14 16 Q14 38 24 41 Q34 38 34 16', 1), p('M20 14 L20 10', 2), p('M28 14 L28 10', 3), p('M24 41 L24 46', 4), p('M21 44 L27 44', 5)]);\n      default: return wrap([c(24, 24, 12, 0)]);\n    }\n  }\n\n  renderVals() {\n    const s = this.state;\n    const prizeLabel = this.props.prizeLabel ?? 'NT$100';\n    const questionText = this.props.questionText ?? 'What will you be doing this long weekend for Dragon Boat Festival?';\n    const icons = ['boat', 'drum', 'zongzi', 'egg', 'pouch'];\n    const labels = { boat: 'DRAGON BOAT', drum: 'FESTIVAL DRUM', zongzi: 'ZONGZI', egg: 'STANDING EGG', pouch: 'SCENTED POUCH' };\n\n    const cards = Array.from({ length: 16 }, (_, i) => {\n      const isWinner = s.winners.includes(i);\n      const isChosen = s.chosen === i;\n      const key = icons[i % 5];\n      return {\n        index: i, num: i + 1,\n        isWinner, isLoser: !isWinner,\n        iconKey: key, iconEl: this.iconEl(key), faceLabel: labels[key],\n        flipT: (isChosen && s.flipped) ? 'rotateY(180deg)' : 'rotateY(0deg)',\n        opacity: (s.chosen !== null && !isChosen) ? 0.32 : 1,\n        lift: isChosen ? 'translateY(-8px) scale(1.05)' : 'translateY(0) scale(1)',\n        onClick: () => this.choose(i),\n      };\n    });\n\n    const avatarColors = ['#9a201a', '#7d4a16', '#3f6b4f', '#8a3a12', '#5a3a7d'];\n    const wallList = (s.participants || []).map((p, idx) => ({\n      name: p.name || 'Anonymous',\n      answer: p.answer || '',\n      won: !!p.won,\n      initial: (p.name || '?').trim().charAt(0).toUpperCase() || '?',\n      avatarBg: p.won ? 'linear-gradient(150deg,#ecc659,#c89a3a)' : avatarColors[idx % avatarColors.length],\n      rowBg: p.won ? '#fbf2d8' : 'transparent',\n    }));\n    const winnerCount = (s.participants || []).filter((p) => p.won).length;\n    const winnerText = winnerCount === 0 ? 'No golden winners yet' :\n      (winnerCount === 1 ? '1 lucky winner so far' : winnerCount + ' lucky winners so far');\n\n    const my = s.myResult || {};\n\n    return {\n      isEntry: s.screen === 'entry',\n      isBoard: s.screen === 'board',\n      isLocked: s.screen === 'locked',\n      showResult: s.showResult,\n      showWall: s.showWall,\n      name: s.name, answer: s.answer,\n      onName: this.onName, onAnswer: this.onAnswer,\n      start: this.start, openWall: this.openWall, closeWall: this.closeWall, reset: this.reset,\n      startOpacity: this.canStart() ? 1 : 0.45,\n      startCursor: this.canStart() ? 'pointer' : 'not-allowed',\n      entryHint: this.canStart() ? '' : 'Enter your name and your weekend plans to play.',\n      prizeLabel, questionText,\n      cards,\n      ovWon: s.won, ovLost: !s.won, ovName: s.name, ovAnswer: s.answer,\n      lkWon: !!my.won, lkLost: !my.won, lkName: my.name || '', lkAnswer: my.answer || '',\n      wallList, wallEmpty: wallList.length === 0, winnerText,\n      confettiRef: (el) => { this._confetti = el; },\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
